<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<!--
  STUB-Vorlage für die Pfleger-Übersicht (AB 04, Workstream B).

  Dieses Skelett liefert TableView, Eingabefelder und Buttons. Was noch fehlt
  und von euch ergänzt werden muss:

    1. fx:controller="de.hitec.nhplus.controller.AllCaregiverController"
       oben im <AnchorPane>-Tag ergänzen, sobald euer Controller existiert.

    2. onAction- und onEditCommit-Handler an Buttons und TableColumns
       eintragen (siehe AllPatientView.fxml als Vorlage).

    3. Spalten und Eingabefelder an die Akzeptanzkriterien eurer User
       Stories aus AB 03 anpassen — der Stub zeigt nur Beispielspalten,
       welche Attribute eine Pflegekraft hat, entscheidet eure Planung.

  Orientiert euch beim Ausfüllen an AllPatientView.fxml — gleicher Aufbau,
  nur andere Domäne.
-->
<AnchorPane prefHeight="500.0" prefWidth="855.0" xmlns="http://javafx.com/javafx/10.0.2-internal" xmlns:fx="http://javafx.com/fxml/1" stylesheets="@Application.css" fx:controller="de.hitec.nhplus.controller.AllCaregiverController">
   <children>
      <TableView fx:id="tableView" editable="true" layoutX="31.0" layoutY="40.0" AnchorPane.bottomAnchor="70.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="80.0">
          <columns>
              <TableColumn fx:id="columnId" maxWidth="50.0" minWidth="5.0" prefWidth="40.0" text="ID" />
              <TableColumn fx:id="columnSurname" maxWidth="7500.0" prefWidth="150.0" text="Nachname" onEditCommit="#handleOnEditSurname" />
              <TableColumn fx:id="columnFirstName" maxWidth="7500.0" prefWidth="150.0" text="Vorname" onEditCommit="#handleOnEditFirstName" />
              <TableColumn fx:id="columnPersonnelNumber" maxWidth="7500.0" prefWidth="150.0" text="Personalnummer" onEditCommit="#handleOnEditPersonnelNumber" />
              <TableColumn fx:id="columnQualification" maxWidth="7500.0" prefWidth="150.0" text="Qualifikation" onEditCommit="#handleOnEditQualification" />
          </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
       <HBox spacing="10.0" AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0">
           <children>
               <TextField fx:id="textFieldFirstName" prefWidth="150.0" promptText="Vorname" />
               <TextField fx:id="textFieldSurname" prefWidth="150.0" promptText="Nachname" />
               <TextField fx:id="textFieldPersonnelNumber" prefWidth="150.0" promptText="Personalnummer" />
               <TextField fx:id="textFieldQualification" prefWidth="150.0" promptText="Qualifikation" />
               <Button fx:id="buttonAdd" mnemonicParsing="false" prefWidth="90.0" text="Hinzufügen" onAction="#handleAdd" />
               <Button fx:id="buttonDelete" mnemonicParsing="false" prefWidth="90.0" text="Löschen" onAction="#handleDelete" />
           </children>
       </HBox>
      <HBox alignment="TOP_CENTER" layoutX="10.0" layoutY="10.0" prefWidth="200.0" spacing="25.0" AnchorPane.leftAnchor="5.0" AnchorPane.rightAnchor="5.0" AnchorPane.topAnchor="5.0">
         <children>
            <Label alignment="CENTER" contentDisplay="CENTER" minWidth="400.0" text="Pfleger/innen" textAlignment="CENTER">
               <font>
                  <Font size="36.0" />
               </font>
            </Label>
         </children>
      </HBox>
   </children>
   <padding>
      <Insets top="10.0" />
   </padding>
</AnchorPane>
